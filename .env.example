# Neon Postgres connection string
# Get it from neon.tech -> your project -> Connection string (use the pooled or direct URL)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/settle?sslmode=require"

# Anthropic API key — powers OCR + AI Bill Review on the Capture screen.
# Optional: if absent, Settle falls back to a deterministic mock parse so the demo always works.
ANTHROPIC_API_KEY=""
